# Single .env at repo root — used by frontend (Vite) and server (Express)
# Copy to .env and fill in values: cp .env.example .env

# --- Server (Express + SMTP) ---
PORT=5000
CONTACT_TO=mehtadevv351@gmail.com

# Gmail SMTP — use App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
# Use 465 on Vercel (587 often hangs on serverless). Use 587 locally if you prefer.
SMTP_PORT=465
SMTP_USER=mehtadevv351@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=mehtadevv351@gmail.com

# --- Frontend (Vite — must be prefixed with VITE_) ---
VITE_API_BASE_URL=/api
VITE_APP_NAME=Dev Mehta | Portfolio
VITE_APP_VERSION=1.0.0
